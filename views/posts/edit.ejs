<%- layout('layout/boilerPlate') %>

  <div class="form-container">
    <div class="form-card">
      <h1 class="form-title">✏️ Edit Moment</h1>
      <p class="form-subtitle">Update your moment's details</p>

      <form method="POST" action="/moments/v1/post/<%= post._id %>?_method=PATCH" enctype="multipart/form-data">
        <!-- Current Media Preview -->
        <div class="form-group">
          <label class="form-label">Current <%= post.mediaType==='video' ? 'Video' : 'Image' %></label>
          <div style="border-radius: 12px; overflow: hidden; margin-bottom: 1rem;">
            <% if (post.mediaType==='video' ) { %>
              <video controls playsinline preload="metadata" style="width: 100%; height: auto; display: block;">
                <source src="<%= post.imageUrl %>#t=0.001" type="video/mp4">
                <source src="<%= post.imageUrl %>#t=0.001" type="video/webm">
                <source src="<%= post.imageUrl %>#t=0.001">
                Your browser does not support the video tag.
              </video>
              <% } else { %>
                <img src="<%= post.imageUrl %>" alt="<%= post.title %>"
                  style="width: 100%; height: auto; display: block;">
                <% } %>
          </div>
        </div>

        <!-- New Media Upload (Optional) -->
        <div class="form-group">
          <label for="imageUrl" class="form-label">Change Image/Video (Optional)</label>
          <input type="file" name="imageUrl" id="imageUrl" class="form-control" accept="image/*,video/*">
          <small style="color: var(--text-secondary); font-size: 0.85rem; display: block; margin-top: 0.5rem;">
            Leave empty to keep the current <%= post.mediaType==='video' ? 'video' : 'image' %>
          </small>
        </div>

        <!-- Title -->
        <div class="form-group">
          <label for="title" class="form-label">Title</label>
          <input type="text" name="title" id="title" class="form-control" value="<%= post.title %>">
        </div>

        <!-- Description -->
        <div class="form-group">
          <label for="description" class="form-label">Description</label>
          <textarea class="form-control" name="description" id="description" rows="4"><%= post.description %></textarea>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="form-submit-btn">
          💾 Save Changes
        </button>
      </form>

      <!-- Back Link -->
      <div style="text-align: center; margin-top: 1.5rem;">
        <a href="/moments/v1/show/<%= post._id %>" style="color: var(--text-secondary); font-size: 0.9rem;">
          ← Cancel and go back
        </a>
      </div>
    </div>
  </div>