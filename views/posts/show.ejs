<%- layout('layout/boilerPlate') %>

  <div class="detail-container">
    <div class="detail-card">

        <!-- Image/Video Section -->
        <div class="detail-image-wrapper" style="background: #000; min-height: 400px;">
          <% if (post.mediaType==='video' ) { %>
            <!-- VIDEO DETECTED -->
            <video controls playsinline preload="metadata" style="width: 100%; max-height: 600px;">
              <source src="<%= post.imageUrl %>#t=0.001" type="video/mp4">
            </video>
            <% } else { %>
              <!-- IMAGE DETECTED -->
              <img class="detail-image" src="<%= post.imageUrl %>" alt="<%= post.title %>" title="Click to zoom">
              <% } %>
        </div>

        <!-- Content Section -->
        <div class="detail-content">
          <h1 class="detail-title">
            <%= post.title %>
          </h1>

          <div class="detail-meta">
            <div class="detail-meta-item">
              <span class="detail-meta-icon">👤</span>
              <span>Posted by <%= post && post.ownername ? post.ownername : "bikram" %></span>
            </div>
            <div class="detail-meta-item">
              <span class="detail-meta-icon">📅</span>
              <span>
                <%= post.createdAt.toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' , year: 'numeric' , month: 'long'
                  , day: 'numeric' , hour: '2-digit' , minute: '2-digit' }) %>
              </span>
            </div>
          </div>

          <p class="detail-description">
            <%= post.description %>
          </p>

          <!-- Action Buttons (only for authorized users) -->
          <% if (currUser && (post.owner._id.equals(currUser._id) || currUser.role==="admin" )) { %>
            <div class="detail-actions">
              <form action="/moments/v1/delete/<%= post._id %>?_method=DELETE" method="POST" style="flex: 1;">
                <button type="submit" class="btn-action btn-delete"
                  onclick="return confirm('Are you sure you want to delete this moment?')">
                  🗑️ Delete
                </button>
              </form>
              <form action="/moments/v1/makeprivate/<%= post._id %>?_method=PATCH" method="POST" style="flex: 1;">
                <button type="submit" class="btn-action btn-delete"
                  onclick="return confirm('Are you sure you want to make this post private')">
                  Make private
                </button>
              </form>
              <a href="/moments/v1/edit/<%= post._id %>" style="flex: 1;">
                <button class="btn-action btn-edit" style="width: 100%;">
                  ✏️ Edit
                </button>
              </a>
            </div>
            <% } %>
        </div>
    </div>

    <!-- Back to Gallery Button -->
    <div style="text-align: center; margin-top: 2rem;">
      <a href="/moments/v1/home"
        style="color: var(--primary-color); font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem;">
        ← Back to Gallery
      </a>
    </div>
  </div>